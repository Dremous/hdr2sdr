+    double peak_luminance;   // 宄板€间寒搴︼紙cd/m^2锛?+    double exposure;         // 鏇濆厜琛ュ伩
+    double saturation;       // 楗卞拰搴?+    int target_color_space;  // 鐩爣鑹插僵绌洪棿锛?=BT.709, 1=BT.2020, 2=DCI-P3
+    int encoder;             // 缂栫爜鍣細0=H.264, 1=H.265, 2=AV1
+    int crf;                 // CRF 璐ㄩ噺鍊?+    int target_width;        // 鐩爣瀹藉害
+    int target_height;       // 鐩爣楂樺害
